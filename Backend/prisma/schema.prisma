// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String

  books      UserBook[]
  ownedClubs  Club[]

  clubMemberships ClubMember[]

  clubDiscussions ClubDiscussion[]
  clubComments    ClubComment[]
  discussionReactions ClubDiscussionReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserBook {

  id           String   @id @default(cuid())

  googleBookId String
  title        String
  authors      String[]
  thumbnail    String?

  pageCount    Int?
  categories   String[]

  status       ReadingStatus

  rating       Int?
  review       String? @db.Text

  finishedAt   DateTime?

  userId       String
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, finishedAt])
}

enum ReadingStatus {
  WANT_TO_READ
  CURRENTLY_READING
  FINISHED
}

model Club {

  id            String   @id @default(cuid())

  // Club Information
  name          String
  description   String
  clubMessage   String? @db.Text
  coverImage    String?

  // Privacy
  isPrivate     Boolean @default(false)

  // Owner
  ownerId       String

  // Current Discussion Book
  googleBookId  String?
  bookTitle     String?
  bookAuthors   String[]
  bookThumbnail String?

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  owner          User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members        ClubMember[]
  discussions    ClubDiscussion[]
}

model ClubMember {
  id String @id @default(cuid())

  clubId String
  userId String

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([clubId, userId])
  @@index([clubId])
}

model ClubDiscussion {
  id        String   @id @default(cuid())

  clubId    String
  userId    String

  message   String   @db.Text

  isPinned  Boolean @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club      Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  comments  ClubComment[]
  reactions ClubDiscussionReaction[]

  @@index([clubId, createdAt])
}

model ClubComment {
  id            String   @id @default(cuid())

  discussionId  String
  userId        String

  content       String   @db.Text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  discussion ClubDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([discussionId])
}

model ClubDiscussionReaction {
  id            String @id @default(cuid())

  discussionId  String
  userId        String

  discussion ClubDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([discussionId, userId])
}
